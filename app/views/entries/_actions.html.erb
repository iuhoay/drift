<%
  read = user_entry&.read_at.present?
  starred = user_entry&.starred_at.present?
%>

<% if starred %>
  <%= button_to entry_star_path(entry), method: :delete, form: { class: "inline" }, class: "term-btn term-btn-on" do %>[★ starred]<% end %>
<% else %>
  <%= button_to entry_star_path(entry), form: { class: "inline" }, class: "term-btn" do %>[☆ star]<% end %>
<% end %>

<% if read %>
  <%= button_to entry_read_path(entry), method: :delete, form: { class: "inline" }, class: "term-btn" do %>[unread]<% end %>
<% else %>
  <%= button_to entry_read_path(entry), form: { class: "inline" }, class: "term-btn" do %>[read]<% end %>
<% end %>
