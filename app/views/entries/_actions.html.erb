<%
  read = user_entry&.read_at.present?
  starred = user_entry&.starred_at.present?
%>

<% if starred %>
  <%= button_to unstar_entry_path(entry), method: :post, form: { class: "inline" }, class: "term-btn term-btn-on" do %>[★ starred]<% end %>
<% else %>
  <%= button_to star_entry_path(entry), method: :post, form: { class: "inline" }, class: "term-btn" do %>[☆ star]<% end %>
<% end %>

<% if read %>
  <%= button_to unread_entry_path(entry), method: :post, form: { class: "inline" }, class: "term-btn" do %>[unread]<% end %>
<% else %>
  <%= button_to read_entry_path(entry), method: :post, form: { class: "inline" }, class: "term-btn" do %>[read]<% end %>
<% end %>
