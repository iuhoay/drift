<% content_for :title, @entry.title %>

<article class="max-w-3xl mx-auto px-5 sm:px-8 py-8">
  <div class="flex items-center justify-between border-b border-stone-300 pb-3 text-sm">
    <%= link_to :back, class: "text-stone-500 hover:text-amber-700" do %>
      <span class="select-none">&larr;</span> back
    <% end %>

    <%# mark-read posts on render, keeping #show a safe GET (Turbo prefetch won't mark read). %>
    <div id="<%= dom_id(@entry, :actions) %>" class="flex items-center gap-2"
         data-controller="mark-read"
         data-mark-read-url-value="<%= entry_read_path(@entry) %>">
      <%= render "entries/actions", entry: @entry, user_entry: @user_entry %>
    </div>
  </div>

  <header class="py-6">
    <div class="mb-3 space-y-0.5 text-xs leading-relaxed">
      <div class="flex gap-3">
        <span class="w-16 shrink-0 select-none text-stone-400">FEED</span>
        <span class="min-w-0 truncate text-stone-600"><%= @entry.feed.display_title %></span>
      </div>
      <% if @entry.published_at %>
        <div class="flex gap-3">
          <span class="w-16 shrink-0 select-none text-stone-400">DATE</span>
          <span class="text-stone-600">
            <%= @entry.published_at.strftime("%Y-%m-%d") %>
            <span aria-hidden="true">&middot;</span>
            <%= @entry.published_at.strftime("%H:%M") %>
          </span>
        </div>
      <% end %>
      <% if @entry.author.present? %>
        <div class="flex gap-3">
          <span class="w-16 shrink-0 select-none text-stone-400">AUTHOR</span>
          <span class="min-w-0 truncate text-stone-600"><%= @entry.author %></span>
        </div>
      <% end %>
      <% if (source_url = @entry.safe_url) %>
        <div class="flex gap-3">
          <span class="w-16 shrink-0 select-none text-stone-400">SOURCE</span>
          <%= link_to source_url, source_url, target: "_blank", rel: "noopener",
                class: "min-w-0 truncate text-amber-700 underline underline-offset-2 hover:bg-amber-700/15" %>
        </div>
      <% end %>
    </div>
    <h1 class="text-2xl sm:text-3xl font-semibold leading-tight tracking-tight text-stone-900"><%= @entry.title.presence || "(untitled)" %></h1>
  </header>

  <% if (video_id = @entry.youtube_video_id) %>
    <div class="border-t border-stone-300 pt-7">
      <div class="relative aspect-video overflow-hidden bg-stone-900">
        <iframe
          src="https://www.youtube.com/embed/<%= video_id %>"
          title="<%= @entry.title %>"
          loading="lazy"
          allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen
          class="absolute inset-0 h-full w-full border-0"></iframe>
      </div>
    </div>
  <% end %>

  <div class="entry-content border-t border-stone-300 pt-7">
    <%= sanitize(@entry.content.presence || @entry.summary.to_s) %>
  </div>

  <div class="mt-12 flex items-center justify-between border-t border-stone-300 pt-3 text-xs text-stone-500">
    <span class="select-none text-stone-400">&mdash; end of entry &mdash;</span>
    <% if (footer_url = @entry.safe_url) %>
      <%= link_to footer_url, target: "_blank", rel: "noopener",
            class: "text-amber-700 underline underline-offset-2 hover:bg-amber-700/15" do %>
        open original <span class="select-none">&#8599;</span>
      <% end %>
    <% end %>
  </div>
</article>
