<% content_for :title, @entry.title %>

<article class="max-w-3xl mx-auto px-6 py-10">
  <div class="mb-6 flex items-center justify-between font-sans text-sm text-stone-500">
    <%= link_to "← Back", :back, class: "hover:text-stone-900" %>

    <div id="<%= dom_id(@entry, :actions) %>" class="flex items-center gap-2">
      <%= render "entries/actions", entry: @entry, user_entry: @user_entry %>
    </div>
  </div>

  <header class="mb-8">
    <div class="text-xs uppercase tracking-widest text-stone-500 font-sans mb-2">
      <%= @entry.feed.display_title %>
      <% if @entry.published_at %>
        · <%= @entry.published_at.strftime("%B %-d, %Y") %>
      <% end %>
      <% if @entry.author.present? %>
        · <%= @entry.author %>
      <% end %>
    </div>
    <h1 class="text-3xl font-semibold tracking-tight leading-tight"><%= @entry.title %></h1>
  </header>

  <div class="entry-content">
    <%= sanitize(@entry.content.presence || @entry.summary.to_s) %>
  </div>

  <% if @entry.url.present? %>
    <div class="mt-12 pt-6 border-t border-stone-200 font-sans text-sm">
      <%= link_to "Open original →", @entry.url, target: "_blank", rel: "noopener", class: "text-stone-700 underline hover:text-stone-900" %>
    </div>
  <% end %>
</article>
