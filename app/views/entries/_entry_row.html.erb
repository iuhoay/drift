<%
  read = user_entry&.read_at.present?
  starred = user_entry&.starred_at.present?
%>
<li id="<%= dom_id(entry) %>" class="py-3 group">
  <%= link_to entry_path(entry), class: "block hover:bg-stone-100/70 -mx-3 px-3 py-2 rounded transition-colors" do %>
    <div class="flex items-start gap-3">
      <span class="mt-2 inline-block w-1.5 h-1.5 rounded-full shrink-0 <%= read ? 'bg-transparent' : 'bg-stone-700' %>"></span>

      <div class="flex-1 min-w-0">
        <div class="flex items-baseline justify-between gap-3 font-sans">
          <span class="text-xs uppercase tracking-wider text-stone-500 truncate"><%= entry.feed.display_title %></span>
          <span class="text-xs text-stone-400 shrink-0"><%= relative_time(entry.published_at || entry.created_at) %></span>
        </div>

        <h2 class="mt-0.5 text-base leading-snug <%= read ? 'text-stone-500 font-normal' : 'text-stone-900 font-medium' %>">
          <% if starred %><span class="text-amber-500 mr-1">★</span><% end %>
          <%= entry.title.presence || "(untitled)" %>
        </h2>

        <% excerpt = entry.excerpt(limit: 200) %>
        <% if excerpt.present? %>
          <p class="mt-1 text-sm text-stone-600 line-clamp-2"><%= excerpt %></p>
        <% end %>
      </div>
    </div>
  <% end %>
</li>
