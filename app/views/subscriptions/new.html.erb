<% content_for :title, "Add feed" %>

<div class="max-w-xl mx-auto px-6 py-10">
  <h1 class="text-xl font-medium tracking-tight mb-1 font-sans">Add a feed</h1>
  <p class="text-sm text-stone-500 mb-6 font-sans">Paste a feed URL or just a site address — we'll find the feed for you.</p>

  <%= form_with model: @subscription, url: subscriptions_path, class: "space-y-4 font-sans" do |f| %>
    <% if @subscription.errors.any? %>
      <div class="rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
        <% @subscription.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= label_tag "subscription[feed_url]", "Feed or site URL", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= text_field_tag "subscription[feed_url]", nil,
            placeholder: "https://example.com",
            autofocus: true,
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none bg-white" %>
    </div>

    <div>
      <%= label_tag "subscription[custom_title]", "Custom title (optional)", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= text_field_tag "subscription[custom_title]", nil,
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none bg-white" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Subscribe", class: "px-4 py-2 rounded bg-stone-900 text-white hover:bg-stone-700" %>
      <%= link_to "Cancel", subscriptions_path, class: "text-sm text-stone-500 hover:text-stone-900" %>
    </div>
  <% end %>
</div>
