<% content_for :title, "Feeds" %>

<div class="max-w-3xl mx-auto px-6 py-8">
  <header class="flex items-baseline justify-between mb-6 font-sans">
    <h1 class="text-xl font-medium tracking-tight">Feeds</h1>
    <%= link_to "Add feed", new_subscription_path,
          class: "px-3 py-1.5 text-sm rounded bg-stone-900 text-white hover:bg-stone-700" %>
  </header>

  <% if @subscriptions.empty? %>
    <p class="text-stone-500 font-sans">You haven't subscribed to anything yet.</p>
  <% else %>
    <ul class="divide-y divide-stone-200 font-sans">
      <% @subscriptions.each do |subscription| %>
        <li class="py-3 flex items-center justify-between gap-4">
          <%= link_to entries_path(feed_id: subscription.feed_id, scope: "unread"), class: "group min-w-0 flex-1" do %>
            <div class="font-medium truncate group-hover:text-amber-700"><%= subscription.display_title %></div>
            <div class="text-xs text-stone-500 truncate">
              <%= subscription.feed.feed_url %>
              <% if subscription.feed.dead? %>
                <span class="ml-2 text-red-600">⚠ unreachable for <%= relative_time(subscription.feed.dead_at) %> — <%= subscription.feed.last_error %></span>
              <% elsif subscription.feed.last_error.present? %>
                <span class="ml-2 text-red-600">⚠ <%= subscription.feed.last_error %></span>
              <% elsif subscription.feed.last_success_at %>
                <span class="ml-2">last fetched <%= relative_time(subscription.feed.last_success_at) %></span>
              <% end %>
            </div>
          <% end %>

          <%= button_to "Unsubscribe", subscription_path(subscription),
                method: :delete,
                form: { data: { turbo_confirm: "Unsubscribe from #{subscription.display_title}?" } },
                class: "text-xs text-stone-500 hover:text-red-600 underline" %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <%# Account controls live in the sidebar on desktop, which is hidden on mobile;
      surface them here so the feeds tab doubles as the mobile account screen. %>
  <div class="mt-8 border-t border-stone-200 pt-4 font-sans text-sm md:hidden">
    <div class="flex items-center justify-between gap-2">
      <%= link_to Current.user.email_address, account_path, class: "truncate text-stone-500 underline hover:text-amber-700" %>
      <%= button_to "Sign out", session_path, method: :delete, form: { class: "inline" },
            class: "shrink-0 text-stone-500 hover:text-red-600" %>
    </div>
    <div class="mt-3 flex items-center justify-between gap-2">
      <%= link_to "Account settings", account_path, class: "text-stone-500 underline hover:text-amber-700" %>
      <%= button_to theme_path, method: :patch, form: { class: "inline", data: { turbo: false } },
            class: "text-stone-500 hover:text-amber-700", title: "Cycle theme (Auto / Light / Dark)" do %>
        Theme: <%= (cookies[:theme] || "auto").downcase %>
      <% end %>
    </div>
  </div>
</div>
