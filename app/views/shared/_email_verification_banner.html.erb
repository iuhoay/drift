<% if Current.user && !Current.user.verified? %>
  <div class="term flex flex-wrap items-center gap-x-2 gap-y-1 border-b border-amber-200 bg-amber-50 px-6 py-2.5 text-sm text-amber-900">
    <span class="select-none opacity-60">[!]</span>
    <span>Verify your email to secure your account.</span>
    <%= button_to "Resend link", email_verifications_path, method: :post,
          form: { class: "inline" }, class: "underline hover:text-amber-700" %>
  </div>
<% end %>
