<%
  counts = unread_counts_for(Current.user)
  total_unread = counts.values.sum
  subs = Current.user.subscriptions.joins(:feed).includes(:feed).order(Arel.sql("LOWER(COALESCE(NULLIF(subscriptions.custom_title, ''), feeds.title, feeds.feed_url))"))
  on_inbox = controller_name == "entries" && action_name == "index" && params[:feed_id].blank?
  on_saved = controller_name == "saved_items"
  saved_unread = Current.user.saved_items.unread.count
  nav_base = "group flex items-center gap-2 border-l-2 px-3 py-1.5 transition-colors"
  nav_on   = "border-amber-700 bg-amber-700/10 text-amber-700"
  nav_off  = "border-transparent text-stone-600 hover:bg-stone-200/60 hover:text-stone-900"
%>
<aside class="hidden w-64 shrink-0 flex-col border-r border-stone-300 bg-stone-100/30 text-sm md:flex">
  <nav class="flex-1 overflow-y-auto py-4">
    <div class="select-none px-3 pb-1 text-[0.65rem] uppercase tracking-[0.2em] text-stone-400">// inbox</div>
    <ul>
      <li>
        <%= link_to entries_path, class: "#{nav_base} #{on_inbox ? nav_on : nav_off}" do %>
          <span class="select-none <%= on_inbox ? 'text-amber-700' : 'text-stone-300 group-hover:text-amber-700' %>">&gt;</span>
          <span class="flex-1">inbox</span>
          <% if total_unread.positive? %><span class="tabular-nums text-xs <%= on_inbox ? 'text-amber-700' : 'text-stone-400' %>"><%= total_unread %></span><% end %>
        <% end %>
      </li>
      <li>
        <%= link_to saved_items_path, class: "#{nav_base} #{on_saved ? nav_on : nav_off}" do %>
          <span class="select-none <%= on_saved ? 'text-amber-700' : 'text-stone-300 group-hover:text-amber-700' %>">&gt;</span>
          <span class="flex-1">read later</span>
          <% if saved_unread.positive? %><span class="tabular-nums text-xs <%= on_saved ? 'text-amber-700' : 'text-stone-400' %>"><%= saved_unread %></span><% end %>
        <% end %>
      </li>
    </ul>

    <div class="mt-5 select-none px-3 pb-1 text-[0.65rem] uppercase tracking-[0.2em] text-stone-400">// stats</div>
    <ul>
      <% on_activity = controller_name == "activities" %>
      <li>
        <%= link_to activity_path, class: "#{nav_base} #{on_activity ? nav_on : nav_off}" do %>
          <span class="select-none <%= on_activity ? 'text-amber-700' : 'text-stone-300 group-hover:text-amber-700' %>">&gt;</span>
          <span class="flex-1">activity</span>
        <% end %>
      </li>
    </ul>

    <div class="mt-5 flex items-center justify-between px-3 pb-1 text-[0.65rem] uppercase tracking-[0.2em] text-stone-400">
      <span class="select-none">// subscriptions</span>
      <%= link_to "[+]", new_subscription_path, class: "hover:text-amber-700", title: "Add feed" %>
    </div>

    <ul>
      <% subs.each do |sub| %>
        <% unread = counts[sub.feed_id].to_i %>
        <% active = params[:feed_id].to_s == sub.feed_id.to_s %>
        <li>
          <%= link_to entries_path(feed_id: sub.feed_id, scope: "unread"), class: "#{nav_base} #{active ? nav_on : nav_off}" do %>
            <span class="select-none <%= active ? 'text-amber-700' : 'text-stone-300 group-hover:text-amber-700' %>"><%= active ? ">" : "·" %></span>
            <span class="flex-1 truncate"><%= sub.display_title %></span>
            <% if unread.positive? %><span class="shrink-0 tabular-nums text-xs <%= active ? 'text-amber-700' : 'text-stone-400' %>"><%= unread %></span><% end %>
          <% end %>
        </li>
      <% end %>
      <% if subs.empty? %>
        <li class="px-3 py-2 text-xs text-stone-500">
          no feeds &mdash; <%= link_to "$ add one", new_subscription_path, class: "text-amber-700 underline underline-offset-2" %>
        </li>
      <% end %>
    </ul>
  </nav>

  <div class="border-t border-stone-300 px-4 py-3 text-xs">
    <div class="flex items-center justify-between gap-2">
      <%= link_to Current.user.email_address, account_path, class: "truncate text-stone-500 hover:text-amber-700", title: "Account" %>
      <%= button_to "[sign out]", session_path, method: :delete, form: { class: "inline" }, class: "shrink-0 text-stone-500 hover:text-amber-700" %>
    </div>
    <div class="mt-2 flex items-center justify-between gap-2 text-stone-500">
      <%= link_to "[manage feeds]", subscriptions_path, class: "hover:text-amber-700" %>
      <%= button_to theme_path, method: :patch, form: { class: "inline", data: { turbo: false } },
            class: "hover:text-amber-700", title: "Cycle theme (Auto / Light / Dark)" do %>
        theme:<%= (cookies[:theme] || "auto").downcase %>
      <% end %>
    </div>
    <div class="mt-2 flex items-center gap-3 text-stone-400">
      <%= link_to "about", about_path, class: "hover:text-amber-700" %>
      <%= link_to "terms", terms_path, class: "hover:text-amber-700" %>
      <%= link_to "privacy", privacy_path, class: "hover:text-amber-700" %>
    </div>
  </div>
</aside>
