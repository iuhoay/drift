<% content_for :title, "Sign in" %>

<p class="text-sm">
  <span class="text-amber-700">drift</span><span class="text-stone-400">:</span><span class="text-stone-500">~/login</span><span class="term-caret select-none" aria-hidden="true"></span>
</p>
<h1 class="mt-4 text-base font-semibold tracking-tight text-stone-900">Sign in to your reader.</h1>

<div class="mt-6">
  <%= render "shared/oauth_buttons" %>

  <%= form_with url: session_url, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :email_address, "email", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
            value: params[:email_address], class: "term-field" %>
    </div>

    <div>
      <%= form.label :password, "password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72,
            class: "term-field" %>
    </div>

    <%= form.submit "sign in", class: "term-submit" %>
  <% end %>
</div>

<div class="mt-6 space-y-1.5 text-sm text-stone-500">
  <p>No account? <%= link_to "create one", new_registration_path, class: "text-amber-700 underline underline-offset-2 hover:text-amber-900" %></p>
  <p><%= link_to "Forgot password?", new_password_path, class: "underline underline-offset-2 hover:text-stone-900" %></p>
</div>

<p class="mt-5 text-xs text-stone-400">
  <%= link_to "Terms", terms_path, class: "underline underline-offset-2 hover:text-stone-700" %>
  <span class="select-none">&middot;</span>
  <%= link_to "Privacy", privacy_path, class: "underline underline-offset-2 hover:text-stone-700" %>
</p>
