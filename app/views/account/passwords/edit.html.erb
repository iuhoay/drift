<% content_for :title, "Change password" %>

<div class="max-w-md mx-auto px-6 py-8 font-sans">
  <header class="mb-6">
    <h1 class="text-xl font-medium tracking-tight">Change password</h1>
    <p class="text-sm text-stone-500">
      Enter your current password to set a new one.
      Signed in with GitHub or Google? Use
      <%= link_to "forgot password", new_password_path, class: "underline" %> to set one.
    </p>
  </header>

  <%= form_with model: @user, url: account_password_path, method: :patch, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
        <% @user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= label_tag :current_password, "Current password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= password_field_tag :current_password, nil, autocomplete: "current-password", maxlength: 72,
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :password, "New password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password", maxlength: 72,
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none" %>
      <p class="text-xs text-stone-500 mt-1">At least 8 characters.</p>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm new password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", maxlength: 72,
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none" %>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Save", class: "px-3 py-1.5 text-sm rounded bg-stone-900 text-white hover:bg-stone-700 cursor-pointer" %>
      <%= link_to "Cancel", account_path, class: "text-sm text-stone-500 underline hover:text-stone-900" %>
    </div>
  <% end %>
</div>
