<%-
  app_name   = Rails.env.production? ? "Drift" : "Drift (#{Rails.env})"
  short_name = Rails.env.production? ? "Drift" : "Drift #{Rails.env.first(3)}"
  theme      = Rails.env.production? ? "#171412" : "#3f2a14"
-%>
{
  "id": "drift-<%= Rails.env %>",
  "name": "<%= app_name %>",
  "short_name": "<%= short_name %>",
  "icons": [
    {
      "src": "/icon-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "/icon.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "/icon.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "start_url": "/",
  "display": "standalone",
  "scope": "/",
  "description": "A calm RSS reader.",
  "theme_color": "<%= theme %>",
  "background_color": "<%= theme %>"
}
