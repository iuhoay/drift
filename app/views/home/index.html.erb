<% content_for :title, "Drift — a calm, distraction-free RSS reader" %>

<%#
  Marketing landing page, shown at the root URL to signed-out visitors only
  (HomeController redirects signed-in readers to their inbox). Rendered in the
  `landing` layout, which carries the brand topbar and footer (legal + Source
  links). Styling stays in the existing terminal vocabulary: mono type, stone
  screen, amber phosphor. Deliberately kept to a single screen — RSS is simple,
  so the page is too.
%>

<%
  cta_primary = "inline-flex items-center border border-stone-900 bg-stone-900 px-4 py-2.5 text-sm text-stone-50 transition-colors hover:border-stone-700 hover:bg-stone-700"

  features = [
    { cmd: "subscribe", body: "Paste a URL and Drift finds the feed for you." },
    { cmd: "read",      body: "Every feed in one timeline, in the order it was published." },
    { cmd: "search",    body: "Full-text search across everything you follow." }
  ]
%>

<section class="mx-auto w-full max-w-2xl px-5 pt-16 pb-24 sm:pt-24">
  <p class="text-sm">
    <span class="text-amber-700">drift</span><span class="text-stone-400">:</span><span class="text-stone-500">~/</span><span class="term-caret select-none" aria-hidden="true"></span>
  </p>

  <h1 class="mt-6 text-3xl font-semibold tracking-tight sm:text-4xl">
    A calm place to read the web.
  </h1>

  <p class="mt-5 max-w-xl leading-relaxed text-stone-600">
    Drift is a fast, distraction-free RSS reader. Subscribe to the sites and
    blogs you follow, and read them in one quiet place — in the order they were
    published, with nothing in between.
  </p>

  <div class="mt-8">
    <%= link_to "[ get started ]", new_registration_path, class: cta_primary %>
  </div>

  <p class="mt-4 text-xs text-stone-500">
    Free and open source. No ads, no tracking, no AI summaries.
  </p>

  <dl class="mt-12 space-y-3 border-t border-stone-200 pt-8 text-sm">
    <% features.each do |feature| %>
      <div class="sm:flex sm:gap-3">
        <dt class="font-medium tracking-tight text-stone-900 sm:w-28 sm:shrink-0">
          <span class="select-none text-amber-700" aria-hidden="true">&gt;</span>
          <%= feature[:cmd] %>
        </dt>
        <dd class="leading-relaxed text-stone-600"><%= feature[:body] %></dd>
      </div>
    <% end %>
  </dl>
</section>
