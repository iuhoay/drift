<!DOCTYPE html>
<html class="h-full" data-theme="<%= cookies[:theme] %>">
  <head>
    <title><%= content_for(:title) || "Drift" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Drift">
    <meta name="mobile-web-app-capable" content="yes">
    <%# Tint the browser chrome to match the page (the stone-100 top bar).
        Safari needs a media-less default plus a dark override; two
        media-qualified tags (which Chrome honors) don't switch in Safari. %>
    <% case cookies[:theme] %>
    <% when "light" %>
      <meta name="theme-color" content="#f5f5f4">
    <% when "dark" %>
      <meta name="theme-color" content="#181614">
    <% else %>
      <meta name="theme-color" content="#f5f5f4">
      <meta name="theme-color" content="#181614" media="(prefers-color-scheme: dark)">
    <% end %>
    <%= tag.meta name: "rails-env", content: Rails.env %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.png" type="image/png">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="manifest" href="<%= pwa_manifest_path %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="term term-screen h-full bg-stone-50 text-stone-900 antialiased">
    <% if authenticated? %>
      <div class="flex h-dvh flex-col overflow-hidden">
        <header class="term-topbar flex min-h-9 shrink-0 items-center justify-between border-b border-stone-300 px-4 pt-[env(safe-area-inset-top)] text-xs">
          <%= link_to root_path, class: "brand-logo text-stone-900", aria: { label: "Drift RSS reader" } do %>
            <span class="brand-logo__rail" aria-hidden="true"></span>
            <span class="brand-logo__name">drift</span>
            <span class="brand-logo__tagline" aria-hidden="true">&#8212; rss reader</span>
          <% end %>
          <div class="flex items-center gap-3 text-stone-400">
            <% if Current.user.admin? %>
              <%= link_to "admin", admin_root_path,
                    class: "hover:text-amber-700 #{'text-amber-700' if controller_path == 'admin/dashboard'}" %>
              <span class="hidden select-none sm:inline" aria-hidden="true">·</span>
            <% end %>
            <%# Mobile-only: the sidebar (which carries account on desktop) is hidden below md. %>
            <%= link_to "account", account_path,
                  class: "md:hidden hover:text-amber-700 #{'text-amber-700' if controller_path.start_with?('account')}" %>
            <span class="hidden select-none sm:block">tty/01</span>
          </div>
        </header>

        <div class="flex flex-1 overflow-hidden">
          <%= render "shared/sidebar" %>

          <main class="flex-1 min-w-0 overflow-y-auto">
            <%= render "shared/email_verification_banner" %>
            <%= render "shared/flash" %>
            <%= yield %>
          </main>
        </div>

        <%= render "shared/bottom_nav" %>
      </div>
    <% else %>
      <main class="flex min-h-dvh items-center justify-center px-4">
        <div class="w-full max-w-md">
          <%= render "shared/flash" %>
          <%= yield %>
        </div>
      </main>
    <% end %>
  </body>
</html>
