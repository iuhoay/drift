<% content_for :title, "Sign up" %>

<div class="bg-white rounded-lg shadow-sm border border-stone-200 px-8 py-10 font-sans">
  <h1 class="text-2xl font-semibold tracking-tight mb-1">Drift</h1>
  <p class="text-sm text-stone-500 mb-6">Create your reader.</p>

  <%= form_with model: @user, url: registration_path, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
        <% @user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :email_address, "Email", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= f.email_field :email_address, autofocus: true, autocomplete: "email",
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none" %>
      <p class="text-xs text-stone-500 mt-1">At least 8 characters.</p>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-3 py-2 rounded border border-stone-300 focus:border-stone-700 focus:outline-none" %>
    </div>

    <%= f.submit "Create account", class: "w-full py-2 rounded bg-stone-900 text-white hover:bg-stone-700" %>
  <% end %>

  <p class="mt-6 text-sm text-stone-500 text-center">
    Already have an account? <%= link_to "Sign in", new_session_path, class: "underline text-stone-900" %>
  </p>
</div>
