<% content_for :title, "Sign up" %>

<p class="text-sm">
  <span class="text-amber-700">drift</span><span class="text-stone-400">:</span><span class="text-stone-500">~/signup</span><span class="term-caret select-none" aria-hidden="true"></span>
</p>
<h1 class="mt-4 text-base font-semibold tracking-tight text-stone-900">Create your reader.</h1>

<div class="mt-6">
  <%= render "shared/oauth_buttons" %>

  <%= form_with model: @user, url: registration_path, class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900">
        <% @user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :email_address, "email", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
      <%= f.email_field :email_address, autofocus: true, autocomplete: "email", class: "term-field" %>
    </div>

    <div>
      <%= f.label :password, "password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "term-field" %>
      <p class="mt-1.5 text-xs text-stone-500">At least 8 characters.</p>
    </div>

    <div>
      <%= f.label :password_confirmation, "confirm password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "term-field" %>
    </div>

    <%= f.submit "create account", class: "term-submit" %>

    <p class="text-xs text-stone-500">
      By creating an account you agree to our
      <%= link_to "Terms", terms_path, class: "text-amber-700 underline underline-offset-2" %>
      and <%= link_to "Privacy Policy", privacy_path, class: "text-amber-700 underline underline-offset-2" %>.
    </p>
  <% end %>
</div>

<p class="mt-6 text-sm text-stone-500">
  Already have an account? <%= link_to "Sign in", new_session_path, class: "text-amber-700 underline underline-offset-2 hover:text-amber-900" %>
</p>
