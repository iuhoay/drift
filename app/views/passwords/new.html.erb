<% content_for :title, "Reset password" %>

<p class="text-sm">
  <span class="text-amber-700">drift</span><span class="text-stone-400">:</span><span class="text-stone-500">~/reset</span><span class="term-caret select-none" aria-hidden="true"></span>
</p>
<h1 class="mt-4 text-base font-semibold tracking-tight text-stone-900">Forgot your password?</h1>
<p class="mt-1.5 text-sm text-stone-500">We&rsquo;ll email you a link to set a new one.</p>

<%= form_with url: passwords_path, class: "mt-6 space-y-4" do |form| %>
  <div>
    <%= form.label :email_address, "email", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
          value: params[:email_address], class: "term-field" %>
  </div>

  <%= form.submit "Email reset instructions", class: "term-submit" %>
<% end %>

<p class="mt-6 text-sm text-stone-500">
  <%= link_to "&larr; Back to sign in".html_safe, new_session_path, class: "text-amber-700 underline underline-offset-2 hover:text-amber-900" %>
</p>
