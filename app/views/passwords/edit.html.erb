<% content_for :title, "Update password" %>

<p class="text-sm">
  <span class="text-amber-700">drift</span><span class="text-stone-400">:</span><span class="text-stone-500">~/reset</span><span class="term-caret select-none" aria-hidden="true"></span>
</p>
<h1 class="mt-4 text-base font-semibold tracking-tight text-stone-900">Update your password</h1>

<%= form_with url: password_path(params[:token]), method: :put, class: "mt-6 space-y-4" do |form| %>
  <div>
    <%= form.label :password, "new password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
    <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72,
          class: "term-field" %>
  </div>

  <div>
    <%= form.label :password_confirmation, "confirm password", class: "block text-xs uppercase tracking-widest text-stone-500 mb-1.5" %>
    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72,
          class: "term-field" %>
  </div>

  <%= form.submit "Save new password", class: "term-submit" %>
<% end %>

<p class="mt-6 text-sm text-stone-500">
  <%= link_to "&larr; Back to sign in".html_safe, new_session_path, class: "text-amber-700 underline underline-offset-2 hover:text-amber-900" %>
</p>
