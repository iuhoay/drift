# Copy to .env and fill in. Drift reads these via Rails 8.2's Rails.app.creds.
# Only needed if your local Postgres differs from the defaults in config/database.yml
# (host=localhost, user=root, password=password). Tests don't read .env — they fall
# through to those defaults. Both .env and .env.* are gitignored via /.env* in .gitignore.

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# Production domain. APP_HOST is the canonical host used for generated URLs
# such as password reset links. APP_HOSTS is optional and can include aliases
# accepted by Host Authorization, for example: rdrift.app,www.rdrift.app.
APP_HOST=rdrift.app
APP_HOSTS=rdrift.app,www.rdrift.app
APP_PROTOCOL=https
